--// 🚀 AUTHENTICATION & LOADING
local function SetStatus(txt, col) 
    StatusLabel.Text = string.upper(txt)
    if col then TweenService:Create(StatusLabel, TweenInfo.new(0.3), {TextColor3 = col}):Play() end 
end

local function CloseUI() 
    TweenService:Create(UIStroke, TweenInfo.new(0.3), {Transparency = 1}):Play()
    Main:TweenSize(UDim2.new(0,0,0,0), "In", "Back", 0.4)
    task.wait(0.4)
    ScreenGui:Destroy() 
end

local function Authenticate(userKey)
    SetStatus("VALIDATING HWID...", Color3.new(1, 1, 0))
    local success, response = pcall(function()
        return http_request({
            Url = API_URL, Method = "POST",
            Headers = {["Content-Type"] = "application/json", ["X-API-KEY"] = API_KEY, ["ngrok-skip-browser-warning"] = "true"},
            Body = HttpService:JSONEncode({key = userKey, user_id = tonumber(lplr.UserId), username = tostring(lplr.Name), hwid = GetHWID()})
        })
    end)
    if success and response and response.StatusCode == 200 then
        local data = HttpService:JSONDecode(response.Body)
        if data.valid then 
            writefile(SAVE_FILE, HttpService:JSONEncode({key = userKey}))
            return true 
        else
            SetStatus("ERR: " .. (data.reason or "INVALID"), Color3.new(1, 0, 0))
            task.wait(2)
        end
    else
        SetStatus("AUTH FAILED", Color3.new(1, 0, 0))
    end
    return false
end

local function LoadHub()
    SetStatus("DOWNLOADING HUB...", Color3.new(1, 1, 1))
    local _, response = pcall(function() return http_request({Url = SCRIPT_SOURCE .. "?t=" .. tick(), Method = "GET"}) end)
    
    if response and response.StatusCode == 200 then
        local func, err = loadstring(response.Body:gsub("\239\187\191", ""))
        if func then 
            CloseUI()
            task.spawn(func)
        else
            warn("Load Error: " .. tostring(err))
            SetStatus("LOAD ERROR", Color3.new(1, 0, 0))
        end
    else
        warn("Download Error: " .. tostring(response and response.StatusCode))
        SetStatus("DOWNLOAD FAILED", Color3.new(1, 0, 0))
    end
end

--// 🎬 STARTUP
LoginBtn.MouseButton1Click:Connect(function()
    if KeyInput.Text == "" then return end
    LoginBtn.Active = false
    if Authenticate(KeyInput.Text) then LoadHub() else LoginBtn.Active = true; SetStatus("PRISM READY", Color3.fromRGB(0, 255, 128)) end
end)

task.spawn(function()
    if isfile(SAVE_FILE) then
        local ok, saved = pcall(function() return HttpService:JSONDecode(readfile(SAVE_FILE)) end)
        if ok and saved.key then 
            if Authenticate(saved.key) then LoadHub() return end 
            pcall(function() delfile(SAVE_FILE) end) 
        end
    end
    SetStatus("PRISM READY", Color3.fromRGB(0, 255, 128))
end)
