--// 🚀 CORE FUNCTIONS
local function SetStatus(txt, col) 
    StatusLabel.Text = string.upper(txt)
    if col then TweenService:Create(StatusLabel, TweenInfo.new(0.3), {TextColor3 = col}):Play() end 
end

local function CloseUI() 
    TweenService:Create(UIStroke, TweenInfo.new(0.3), {Transparency = 1}):Play()
    Main:TweenSize(UDim2.new(0,0,0,0), "In", "Back", 0.4)
    task.wait(0.4)
    ScreenGui:Destroy() 
end

local function Authenticate(userKey)
    SetStatus("VALIDATING HWID...", Color3.new(1, 1, 0))
    local success, response = pcall(function()
        return http_request({
            Url = API_URL, Method = "POST",
            Headers = {["Content-Type"] = "application/json", ["X-API-KEY"] = API_KEY, ["ngrok-skip-browser-warning"] = "true"},
            Body = HttpService:JSONEncode({key = userKey, user_id = tonumber(lplr.UserId), username = tostring(lplr.Name), hwid = GetHWID()})
        })
    end)
    if success and response and response.StatusCode == 200 then
        local data = HttpService:JSONDecode(response.Body)
        if data.valid then 
            writefile(SAVE_FILE, HttpService:JSONEncode({key = userKey}))
            return true 
        end
    end
    return false
end

local function LoadHub()
    SetStatus("DOWNLOADING HUB...", Color3.new(1, 1, 1))
    local _, response = pcall(function() 
        return http_request({
            Url = SCRIPT_SOURCE .. "?t=" .. tick(), 
            Method = "GET",
            Headers = { ["Authorization"] = "token " .. GetSecret(), ["Accept"] = "application/vnd.github.v3.raw" }
        }) 
    end)
    
    if response and response.StatusCode == 200 then
        local func, err = loadstring(response.Body:gsub("\239\187\191", ""))
        if func then CloseUI(); task.spawn(func) else SetStatus("SCRIPT ERROR", Color3.new(1, 0, 0)); warn(err) end
    else
        SetStatus("DOWNLOAD FAILED", Color3.new(1, 0, 0))
        warn("Status Code: " .. tostring(response and response.StatusCode))
    end
end

